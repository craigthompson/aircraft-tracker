# .env is gitignored, use .env.example to build a new `.env` file.
# This project uses dotenv to load .env file

# PostgreSQL Database Creds
DATABASE_USER=
DATABASE_PASSWORD=

# OpenSky Network (OAuth2 client credentials - basic auth deprecated March 18, 2026)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Openaip Aeronautical Charts.
VITE_OPENAIP_CLIENT_ID=

# OpenWeatherMap (cloud cover layer)
VITE_OPENWEATHERMAP_API_KEY=